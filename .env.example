# ============================================================
# Multi-Cloud Migration Platform — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env with real secrets to version control.

# ── Database ────────────────────────────────────────────────
# PostgreSQL credentials (used by docker-compose)
DB_USER=postgres
DB_PASSWORD=postgres

# ── Encryption ──────────────────────────────────────────────
# REQUIRED — 32-byte (256-bit) random key for AES-GCM credential encryption.
# Generate with: openssl rand -base64 32
# Both the API server and the worker will refuse to start without this.
ENCRYPTION_SECRET_KEY=

# ── OAuth — Google ──────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Authorised redirect URI: http://localhost:8001/api/oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OAuth — Google Photos ─────────────────────────────────
# Separate OAuth client with the narrow scopes below. Google Photos is a
# DISTINCT provider from generic Google (Drive/Calendar/Contacts) and requires
# its own client ID/secret — the scopes are not interchangeable.
# Create an app at https://console.cloud.google.com/apis/credentials
# (can reuse the same Google Cloud project as GOOGLE_*).
# Enable the "Google Photos Library API" and request the scopes:
#   https://www.googleapis.com/auth/photoslibrary.readonly.appcreateddata
#   https://www.googleapis.com/auth/photoslibrary.appendonly
# (The full "photoslibrary" scope is NOT used — narrow scopes avoid consent
# rejection on unverified projects. Existing users must reconnect after a scope
# change.)
# Authorised redirect URI: http://localhost:8001/api/oauth/callback
GOOGLE_PHOTOS_CLIENT_ID=
GOOGLE_PHOTOS_CLIENT_SECRET=

# ── OAuth — Dropbox ─────────────────────────────────────────
# Create an app at https://www.dropbox.com/developers/apps
# OAuth 2 redirect URI: http://localhost:8001/api/oauth/callback
DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=

# ── OAuth redirect URI (optional override) ─────────────────
# Only set this if the API is behind a reverse proxy and the
# auto-detected redirect URI is incorrect.
# OAUTH_REDIRECT_URI=https://migration.example.com/api/oauth/callback

# ── Security & Authentication ───────────────────────────────
# REQUIRED — HMAC key for signing JWT sessions (must be different from ENCRYPTION_SECRET_KEY).
# Generate with: openssl rand -base64 32
JWT_SECRET_KEY=

# ── Admin Bootstrap ──────────────────────────────────────────
# Optional: create an initial ADMIN account from environment identity on
# first start (idempotent across restarts). A strong random password is
# generated and printed to the api-backend logs exactly once; the admin must
# rotate it on first login (must_change_password = TRUE). Leave both unset to
# disable bootstrap (you can still promote a user to ADMIN from an existing
# admin session). Only the api-backend reads these — the worker ignores them.
# WARNING: never pre-register this email via open signup, otherwise the
# bootstrap cannot claim it.
#
# WHERE THE PASSWORD IS VISIBLE:
# On first boot the api-backend generates a strong random 24-char password and
# prints it EXACTLY ONCE to STDOUT (the container/process logs), e.g.:
#   BOOTSTRAP ADMIN created — email=admin@example.com password=<random> (rotate on first login)
# The password is NEVER stored in plaintext (only the bcrypt hash in the DB) and
# is not recoverable afterwards. Capture it from the startup logs, log in, and
# change it immediately — must_change_password=TRUE forces a password change.
ADMIN_EMAIL=
ADMIN_DISPLAY_NAME=

# ── Local Storage Provider ──────────────────────────────────
# Optional: enables the "Local" storage provider, which reads/writes files
# directly from a server-side sandbox directory. No URL/username/password
# is required. The "Local" option only appears in the UI when configured.
# Absolute paths and ".." traversal are rejected.
#
# IMPORTANT — Docker: LOCAL_STORAGE_ROOT is the path INSIDE the container and
# is fixed to /clumoove in the compose files. The backend/worker only ever see
# the container path. To expose a real folder, set LOCAL_STORAGE_HOST_PATH to
# the directory ON THE HOST; compose mounts it to /clumoove for both the
# api-backend AND the worker (the worker performs the actual file I/O).
#   Example (Windows host): LOCAL_STORAGE_HOST_PATH=D:/clumoove-data
#   Example (Linux host):   LOCAL_STORAGE_HOST_PATH=/srv/clumoove-data
# If unset, compose falls back to ./local-storage next to the compose file.
LOCAL_STORAGE_HOST_PATH=

# ── CORS & Hosts Whitelisting ───────────────────────────────
# Allowed CORS Origin for API requests in production.
CORS_ALLOWED_ORIGIN=

# Allowed Hosts for Vite frontend dev server (e.g. localhost, hostnames separated by comma).
VITE_ALLOWED_HOSTS=

# ── Indexing / Timeouts ──────────────────────────────────────
# Maximum duration for a single indexing run (BFS traversal of the source tree).
# Raise this for very large trees (e.g. full NAS backups). Default: 60 (minutes).
INDEXING_TIMEOUT_MINUTES=60

# Per-request timeout for a single WebDAV/Nextcloud PROPFIND directory listing.
# Raise this for folders that are slow to enumerate (e.g. large Calibre libraries).
# Default: 120 (seconds). Transient timeouts are retried up to 3 times with backoff.
WEBDAV_LISTING_TIMEOUT_SECONDS=120

# ── Logging & Tracing ───────────────────────────────────────
# Enable full HTTP/WebDAV request and response tracing in worker/backend logs.
# Set to "1" to log all outgoing HTTP requests, headers, status codes, and durations.
# Default: unset (only logs HTTP errors >= 400).
# LOG_HTTP_TRACE=1

# ── Worker Parallelism ───────────────────────────────────────
# Global max parallel tasks per worker process across ALL migrations
# (NOT per migration — that is set per migration via the threads slider, max 16).
# If unset, the worker defaults to 16. Raise this above the per-migration
# max (16) only if you run several migrations concurrently.
# Used by docker-compose.prod.yml; also read by the API for the DB connection pool.
MAX_THREADS=16

# ── Redis Password ──────────────────────────────────────────
# Custom password for internal Redis queue. REQUIRED — the API and worker
# refuse to start with an empty or known-default password. Generate a strong,
# unique value (e.g. `openssl rand -base64 32`) for every deployment.
REDIS_PASSWORD=change-me-to-a-strong-unique-value

# ── System SMTP (Password Reset) ────────────────────────────
# Optional: If not set, password reset feature is disabled in UI
# Encryption: "tls" (implicit/SSL, e.g. port 465) or "starttls" (port 587).
# For STRATO use SMTP_PORT=465 and SMTP_ENCRYPTION=tls.
SMTP_HOST=
SMTP_PORT=587
SMTP_ENCRYPTION=starttls
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Clumoove
FRONTEND_URL=http://localhost:5173

# ── Local Storage Provider ────────────────────────────────
# See the LOCAL_STORAGE_HOST_PATH note above. Set the HOST directory here;
# compose mounts it to the fixed container path /clumoove for api + worker.
# LOCAL_STORAGE_HOST_PATH=/var/lib/clumoove/local-storage
